AIHUB_DATA_DIR=/DATA/3waAIHub/data
AIHUB_MODELS_DIR=/DATA/models
AIHUB_CACHE_DIR=/DATA/3waAIHub/data/cache
AIHUB_UPLOADS_DIR=/DATA/3waAIHub/data/uploads
AIHUB_RESULTS_DIR=/DATA/3waAIHub/data/results
AIHUB_LOGS_DIR=/DATA/3waAIHub/data/logs
# Pack manifests may only reduce this 64 MiB artifact-output ceiling.
AIHUB_PACK_OUTPUT_HARD_MAX_BYTES=67108864
# Validator traversal ceilings; deployment overrides may only reduce these defaults.
AIHUB_PACK_OUTPUT_HARD_MAX_ENTRIES=128
AIHUB_PACK_OUTPUT_HARD_MAX_DEPTH=16
AIHUB_PACK_OUTPUT_HARD_MAX_TOTAL_BYTES=67108864

AIHUB_DOCKER_PORT_START=18100
AIHUB_DOCKER_PORT_END=18999
AIHUB_AUTO_BUILD_MISSING_IMAGE=1
