{
  "schema_version": "0.1",
  "id": "yolo",
  "name": "YOLO Object Detection Service",
  "version": "0.1.0",
  "category": "vision",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L5-benchmark-ready",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "yolo",
  "description": "YOLO object detection API with storage mount, model init smoke, real inference, and benchmark contract.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/detect/image",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 50
  },
  "l5_contract": {
    "endpoint": "/detect/image",
    "method": "POST",
    "content_type": "multipart/form-data",
    "input": {
      "fields": [
        {
          "name": "image",
          "type": "file",
          "required": true,
          "max_mb": 50
        },
        {
          "name": "real_inference",
          "type": "boolean",
          "required": false,
          "default": "0",
          "description": "Set to 1 to run YOLO real image detection for this request."
        },
        {
          "name": "conf",
          "type": "number",
          "required": false,
          "default": "0.25"
        },
        {
          "name": "iou",
          "type": "number",
          "required": false,
          "default": "0.7"
        }
      ]
    },
    "output": {
      "required_keys": ["ok", "detections"],
      "detection_keys": ["class_id", "label", "confidence", "bbox"]
    },
    "errors": [
      "bad_request",
      "file_too_large",
      "runtime_not_ready",
      "inference_failed",
      "gateway_timeout"
    ],
    "limits": {
      "timeout_sec": 180,
      "max_upload_mb": 50,
      "max_concurrency": 1
    },
    "benchmark": {
      "supported": true,
      "cases": [
        {
          "id": "yolo_mock_image",
          "name": "YOLO mock image smoke",
          "type": "api",
          "mode": "yolo",
          "method": "POST",
          "fixture": "packs/yolo/demo/sample.jpg",
          "expected_keys": ["ok", "detections"]
        },
        {
          "id": "yolo_real_image",
          "name": "YOLO real image detection smoke",
          "type": "api",
          "mode": "yolo",
          "method": "POST",
          "fixture": "packs/yolo/demo/real_sample.jpg",
          "expected_keys": ["ok", "detections"],
          "real_inference": true
        }
      ]
    }
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": true,
    "min_vram_mb": 0,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "gpu",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "yolo",
        "container_path": "/models/yolo",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "yolo",
        "container_path": "/cache/yolo",
        "read_only": false
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "settings_schema": [
    {
      "key": "YOLO_MODEL",
      "label": "YOLO model",
      "type": "text",
      "default": "yolo11n.pt",
      "required": true,
      "restart_required": true,
      "model_selector": {
        "type": "file",
        "root_subdir": "yolo",
        "extensions": [".pt", ".onnx"]
      }
    },
    {
      "key": "YOLO_CONF",
      "label": "Confidence threshold",
      "type": "number",
      "default": "0.25",
      "min": 0,
      "max": 1,
      "required": true,
      "restart_required": true
    },
    {
      "key": "YOLO_IOU",
      "label": "IoU threshold",
      "type": "number",
      "default": "0.7",
      "min": 0,
      "max": 1,
      "required": true,
      "restart_required": true
    },
    {
      "key": "YOLO_USE_GPU",
      "label": "Use GPU",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "KEEP_WARM",
      "label": "Keep model warm",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "YOLO_REAL_INFERENCE",
      "label": "Enable real YOLO detection",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "Default to mock mode unless this is enabled or a request explicitly sets real_inference=1."
    }
  ],
  "env": [
    {
      "name": "YOLO_MODEL",
      "default": "yolo11n.pt",
      "required": true
    },
    {
      "name": "YOLO_REAL_INFERENCE",
      "default": "0",
      "required": true
    },
    {
      "name": "YOLO_CONF",
      "default": "0.25",
      "required": true
    },
    {
      "name": "YOLO_IOU",
      "default": "0.7",
      "required": true
    },
    {
      "name": "YOLO_USE_GPU",
      "default": "0",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18105,
    "local_port_env": "YOLO_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "yolo-main",
    "compose_project": "3waaihub_yolo_main"
  }
}
