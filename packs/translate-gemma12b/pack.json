{
  "schema_version": "0.1",
  "id": "translate-gemma12b",
  "name": "TranslateGemma 12B Translation Service",
  "version": "0.1.0",
  "category": "translation",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L5-benchmark-ready",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "translate",
  "description": "Translation API adapter with an Ollama sidecar and host-level model storage mount.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/translate",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 2
  },
  "l5_contract": {
    "endpoint": "/translate",
    "method": "POST",
    "content_type": "application/json",
    "input": {
      "fields": [
        {
          "name": "source_lang",
          "type": "string",
          "required": false,
          "default": "auto"
        },
        {
          "name": "target_lang",
          "type": "string",
          "required": true,
          "default": "zh-TW"
        },
        {
          "name": "text",
          "type": "string",
          "required": true
        },
        {
          "name": "real_inference",
          "type": "boolean",
          "required": false,
          "default": false
        }
      ]
    },
    "output": {
      "required_keys": ["ok", "mock", "runtime_level", "model", "source_lang", "target_lang", "text", "elapsed_ms"]
    },
    "errors": [
      "bad_request",
      "input_too_long",
      "ollama_unavailable",
      "model_not_present",
      "ollama_timeout",
      "ollama_bad_response",
      "translation_failed"
    ],
    "limits": {
      "max_input_chars": "MAX_INPUT_CHARS",
      "default_timeout_seconds": 180,
      "max_concurrency": 1
    },
    "benchmark": {
      "supported": true,
      "cases": [
        {
          "id": "translate_mock_text",
          "name": "TranslateGemma mock text smoke",
          "type": "api",
          "mode": "translate",
          "method": "POST",
          "content_type": "application/json",
          "body_json": {
            "source_lang": "en",
            "target_lang": "zh-TW",
            "text": "That was a wonderful time."
          },
          "expected_keys": ["ok", "mock", "runtime_level", "model", "source_lang", "target_lang", "text", "elapsed_ms"],
          "expected_mock": true,
          "expected_text_non_empty": true
        },
        {
          "id": "translate_real_text",
          "name": "TranslateGemma real text inference smoke",
          "type": "api",
          "mode": "translate",
          "method": "POST",
          "content_type": "application/json",
          "body_json": {
            "source_lang": "en",
            "target_lang": "zh-TW",
            "text": "That was a wonderful time.",
            "real_inference": 1
          },
          "expected_keys": ["ok", "mock", "runtime_level", "model", "source_lang", "target_lang", "text", "elapsed_ms"],
          "expected_mock": false,
          "expected_text_non_empty": true,
          "expected_text_not_equal_input": true,
          "expected_cjk": true,
          "expected_model": "translategemma:12b-it-q4_K_M",
          "expected_target_lang": "zh-TW",
          "real_inference": true
        }
      ]
    }
  },
  "hardware": {
    "gpu_required": true,
    "gpu_supported": true,
    "min_vram_mb": 10000,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "gpu",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "ollama",
        "container_path": "/root/.ollama",
        "read_only": false,
        "target_service": "ollama"
      },
      {
        "type": "cache",
        "host_subdir": "translate",
        "container_path": "/cache/translate",
        "read_only": false,
        "target_service": "translator-api"
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false,
        "target_service": "translator-api"
      }
    ]
  },
  "settings_schema": [
    {
      "key": "OLLAMA_MODEL",
      "label": "Ollama model",
      "type": "text",
      "default": "translategemma:12b-it-q4_K_M",
      "required": true,
      "restart_required": true,
      "model_selector": {
        "type": "ollama_tag",
        "root_subdir": "ollama"
      }
    },
    {
      "key": "KEEP_WARM",
      "label": "Keep model warm",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "MAX_INPUT_CHARS",
      "label": "Max input chars",
      "type": "integer",
      "default": "12000",
      "min": 100,
      "max": 100000,
      "required": true,
      "restart_required": false
    },
    {
      "key": "TEMPERATURE",
      "label": "Temperature",
      "type": "number",
      "default": "0",
      "min": 0,
      "max": 2,
      "required": true,
      "restart_required": false
    },
    {
      "key": "OLLAMA_NUM_CTX",
      "label": "Context window",
      "type": "integer",
      "default": "4096",
      "min": 512,
      "max": 32768,
      "required": false,
      "restart_required": true
    },
    {
      "key": "GPU_VISIBLE_DEVICES",
      "label": "GPU visible devices",
      "type": "text",
      "default": "all",
      "required": false,
      "restart_required": true
    },
    {
      "key": "TRANSLATE_REAL_INFERENCE",
      "label": "Enable real translation",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "OLLAMA_KEEP_ALIVE",
      "label": "Ollama keep alive",
      "type": "text",
      "default": "5m",
      "required": false,
      "restart_required": true
    }
  ],
  "env": [
    {
      "name": "OLLAMA_MODEL",
      "default": "translategemma:12b-it-q4_K_M",
      "required": true
    },
    {
      "name": "OLLAMA_BASE_URL",
      "default": "http://ollama:11434",
      "required": true
    },
    {
      "name": "OLLAMA_KEEP_ALIVE",
      "default": "5m",
      "required": false
    },
    {
      "name": "MAX_INPUT_CHARS",
      "default": "12000",
      "required": true
    },
    {
      "name": "TEMPERATURE",
      "default": "0",
      "required": false
    },
    {
      "name": "OLLAMA_NUM_CTX",
      "default": "4096",
      "required": false
    },
    {
      "name": "KEEP_WARM",
      "default": "0",
      "required": true
    },
    {
      "name": "TRANSLATE_REAL_INFERENCE",
      "default": "0",
      "required": true
    },
    {
      "name": "GPU_VISIBLE_DEVICES",
      "default": "all",
      "required": false
    }
  ],
  "models": [
    {
      "id": "translategemma-12b-q4km",
      "runtime": "ollama",
      "model": "translategemma:12b-it-q4_K_M",
      "required": false
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "vram",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18102,
    "local_port_env": "TRANSLATE_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "translate-main",
    "compose_project": "3waaihub_translate_main"
  }
}
