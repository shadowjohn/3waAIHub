{
  "schema_version": "0.1",
  "id": "translate-gemma12b",
  "name": "TranslateGemma 12B Translation Service",
  "version": "0.1.0",
  "category": "translation",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L3-storage-mount",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "translate",
  "description": "Translation API adapter with an Ollama sidecar and host-level model storage mount.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/translate",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 2
  },
  "hardware": {
    "gpu_required": true,
    "gpu_supported": true,
    "min_vram_mb": 10000,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "gpu",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "ollama",
        "container_path": "/root/.ollama",
        "read_only": false,
        "target_service": "ollama"
      },
      {
        "type": "cache",
        "host_subdir": "translate",
        "container_path": "/cache/translate",
        "read_only": false,
        "target_service": "translator-api"
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false,
        "target_service": "translator-api"
      }
    ]
  },
  "settings_schema": [
    {
      "key": "OLLAMA_MODEL",
      "label": "Ollama model",
      "type": "text",
      "default": "translategemma:12b-it-q4_K_M",
      "required": true,
      "restart_required": true,
      "model_selector": {
        "type": "ollama_tag",
        "root_subdir": "ollama"
      }
    },
    {
      "key": "KEEP_WARM",
      "label": "Keep model warm",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "MAX_INPUT_CHARS",
      "label": "Max input chars",
      "type": "integer",
      "default": "12000",
      "min": 100,
      "max": 100000,
      "required": true,
      "restart_required": false
    },
    {
      "key": "TEMPERATURE",
      "label": "Temperature",
      "type": "number",
      "default": "0",
      "min": 0,
      "max": 2,
      "required": true,
      "restart_required": false
    },
    {
      "key": "OLLAMA_NUM_CTX",
      "label": "Context window",
      "type": "integer",
      "default": "4096",
      "min": 512,
      "max": 32768,
      "required": false,
      "restart_required": true
    },
    {
      "key": "GPU_VISIBLE_DEVICES",
      "label": "GPU visible devices",
      "type": "text",
      "default": "all",
      "required": false,
      "restart_required": true
    },
    {
      "key": "TRANSLATE_REAL_INFERENCE",
      "label": "Enable real translation",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "OLLAMA_KEEP_ALIVE",
      "label": "Ollama keep alive",
      "type": "text",
      "default": "5m",
      "required": false,
      "restart_required": true
    }
  ],
  "env": [
    {
      "name": "OLLAMA_MODEL",
      "default": "translategemma:12b-it-q4_K_M",
      "required": true
    },
    {
      "name": "OLLAMA_BASE_URL",
      "default": "http://ollama:11434",
      "required": true
    },
    {
      "name": "OLLAMA_KEEP_ALIVE",
      "default": "5m",
      "required": false
    },
    {
      "name": "MAX_INPUT_CHARS",
      "default": "12000",
      "required": true
    },
    {
      "name": "TEMPERATURE",
      "default": "0",
      "required": false
    },
    {
      "name": "OLLAMA_NUM_CTX",
      "default": "4096",
      "required": false
    },
    {
      "name": "KEEP_WARM",
      "default": "0",
      "required": true
    },
    {
      "name": "TRANSLATE_REAL_INFERENCE",
      "default": "0",
      "required": true
    },
    {
      "name": "GPU_VISIBLE_DEVICES",
      "default": "all",
      "required": false
    }
  ],
  "models": [
    {
      "id": "translategemma-12b-q4km",
      "runtime": "ollama",
      "model": "translategemma:12b-it-q4_K_M",
      "required": false
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "vram",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18102,
    "local_port_env": "TRANSLATE_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "translate-main",
    "compose_project": "3waaihub_translate_main"
  }
}
