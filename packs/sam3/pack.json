{
  "schema_version": "0.1",
  "id": "sam3",
  "name": "SAM3 Segmentation Service",
  "version": "0.1.0",
  "category": "vision",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L5-benchmark-ready",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "sam3",
  "description": "SAM3 segmentation API adapter with single-image real inference smoke and benchmark contract.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/segment/image",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 50
  },
  "l5_contract": {
    "endpoint": "/segment/image",
    "method": "POST",
    "content_type": "multipart/form-data",
    "input": {
      "fields": [
        {
          "name": "image",
          "type": "file",
          "required": true,
          "max_mb": 50
        },
        {
          "name": "guidance_mask",
          "type": "file",
          "required": false,
          "description": "PNG mask for prompt_type=guidance_mask. Must match image dimensions. Non-transparent pixels are positive guidance; transparent pixels are neutral."
        },
        {
          "name": "prompt_type",
          "type": "string",
          "required": false,
          "default": "auto",
          "enum": ["auto", "points", "boxes", "text", "guidance_mask"]
        },
        {
          "name": "points_json",
          "type": "json",
          "required": false,
          "description": "For prompt_type=points. Format: {\"points\":[[x,y]],\"labels\":[1]}; labels: 1 selects target, 0 excludes target. At least one positive label is required; negative points only refine exclusion."
        },
        {
          "name": "boxes_json",
          "type": "json",
          "required": false
        },
        {
          "name": "text",
          "type": "string",
          "required": false,
          "description": "Semantic concept prompt for SAM3, e.g. mammal/insect/plant. Use prompt_type=text."
        },
        {
          "name": "real_inference",
          "type": "boolean",
          "required": false,
          "default": "0"
        },
        {
          "name": "output_format",
          "type": "string",
          "required": false,
          "default": "metadata",
          "enum": ["metadata", "polygon", "rle", "both", "png"],
          "example": "png",
          "description": "png returns a merged binary image/png mask response instead of JSON. White/opaque is selected foreground; transparent is background."
        }
      ]
    },
    "output": {
      "required_keys": ["ok", "mock", "runtime_level", "prompt_type", "output_format", "masks", "elapsed_ms"],
      "mask_keys": ["id", "score", "confidence", "label_name", "bbox", "area"],
      "mask_optional_keys": ["polygon", "polygons", "rle"],
      "binary_formats": {
          "png": {
            "content_type": "image/png",
            "description": "Merged binary mask PNG. White/opaque is selected foreground, transparent is background."
          }
      }
    },
    "errors": [
      "bad_request",
      "model_not_present",
      "model_load_failed",
      "runtime_dependency_missing",
      "bad_image",
      "invalid_prompt",
      "invalid_output_format",
      "invalid_guidance_mask",
      "guidance_mask_size_mismatch",
      "no_positive_guidance",
      "polygon_extract_failed",
      "rle_encode_failed",
      "gpu_unavailable",
      "inference_failed",
      "inference_timeout"
    ],
    "limits": {
      "timeout_sec": 180,
      "max_upload_mb": 50,
      "max_concurrency": 1
    },
    "benchmark": {
      "supported": true,
      "cases": [
        {
          "id": "sam3_mock_image",
          "name": "SAM3 mock image segmentation smoke",
          "type": "api",
          "mode": "sam3",
          "method": "POST",
          "fixture": "packs/sam3/demo/camera_cat.png",
          "expected_keys": ["ok", "mock", "runtime_level", "prompt_type", "output_format", "masks", "elapsed_ms"],
          "expected_mock": true
        },
        {
          "id": "sam3_real_image",
          "name": "SAM3 real image segmentation smoke",
          "type": "api",
          "mode": "sam3",
          "method": "POST",
          "fixture": "packs/sam3/demo/camera_cat.png",
          "expected_keys": ["ok", "mock", "runtime_level", "model", "prompt_type", "output_format", "masks", "elapsed_ms"],
          "expected_mock": false,
          "expected_elapsed_ms_positive": true,
          "expected_model_checkpoint": true,
          "real_inference": true
        },
        {
          "id": "sam3_real_polygon_image",
          "name": "SAM3 real image polygon smoke",
          "type": "api",
          "mode": "sam3",
          "method": "POST",
          "fixture": "packs/sam3/demo/camera_cat.png",
          "form": {
            "output_format": "polygon"
          },
          "expected_keys": ["ok", "mock", "runtime_level", "model", "prompt_type", "output_format", "masks", "elapsed_ms"],
          "expected_mock": false,
          "expected_elapsed_ms_positive": true,
          "expected_model_checkpoint": true,
          "expected_mask_key": "polygon",
          "real_inference": true
        },
        {
          "id": "sam3_real_png_mask",
          "name": "SAM3 real image PNG mask smoke",
          "type": "api",
          "mode": "sam3",
          "method": "POST",
          "fixture": "packs/sam3/demo/camera_cat.png",
          "form": {
            "output_format": "png"
          },
          "expected_content_type": "image/png",
          "real_inference": true
        }
      ]
    }
  },
  "error_codes": [
    "bad_request",
    "model_not_present",
    "model_load_failed",
    "runtime_dependency_missing",
    "bad_image",
    "invalid_prompt",
    "invalid_output_format",
    "invalid_guidance_mask",
    "guidance_mask_size_mismatch",
    "no_positive_guidance",
    "polygon_extract_failed",
    "rle_encode_failed",
    "gpu_unavailable",
    "inference_failed",
    "inference_timeout"
  ],
  "hardware": {
    "gpu_required": true,
    "gpu_supported": true,
    "min_vram_mb": 16000,
    "recommended_vram_mb": 24000,
    "cpu_fallback": false,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "gpu",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "sam3",
        "container_path": "/models/sam3",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "sam3",
        "container_path": "/cache/sam3",
        "read_only": false
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "settings_schema": [
    {
      "key": "SAM3_CHECKPOINT",
      "label": "SAM3 checkpoint",
      "type": "text",
      "default": "",
      "required": false,
      "restart_required": true,
      "model_selector": {
        "type": "file",
        "root_subdir": "sam3",
        "extensions": [".pt", ".pth", ".safetensors", ".ckpt"]
      }
    },
    {
      "key": "SAM3_MODEL_ID",
      "label": "SAM3 model id",
      "type": "text",
      "default": "",
      "required": false,
      "restart_required": true
    },
    {
      "key": "SAM3_DEVICE",
      "label": "Device",
      "type": "select",
      "default": "auto",
      "options": ["auto", "cuda", "cpu"],
      "required": true,
      "restart_required": true
    },
    {
      "key": "SAM3_MAX_UPLOAD_MB",
      "label": "Max upload MB",
      "type": "integer",
      "default": "50",
      "min": 1,
      "max": 1024,
      "required": true,
      "restart_required": false
    },
    {
      "key": "SAM3_REAL_INFERENCE",
      "label": "Enable real SAM3 inference",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "Enable single-image SAM3 real inference smoke."
    },
    {
      "key": "SAM3_POLYGON_EPSILON",
      "label": "Polygon epsilon",
      "type": "number",
      "default": "2.0",
      "required": true,
      "restart_required": false
    },
    {
      "key": "SAM3_MAX_POLYGON_POINTS",
      "label": "Max polygon points",
      "type": "integer",
      "default": "2000",
      "min": 10,
      "max": 100000,
      "required": true,
      "restart_required": false
    },
    {
      "key": "SAM3_MIN_CONTOUR_AREA",
      "label": "Min contour area",
      "type": "number",
      "default": "16",
      "required": true,
      "restart_required": false
    }
  ],
  "env": [
    {
      "name": "SAM3_CHECKPOINT",
      "default": "",
      "required": false
    },
    {
      "name": "SAM3_MODEL_ID",
      "default": "",
      "required": false
    },
    {
      "name": "SAM3_DEVICE",
      "default": "auto",
      "required": true
    },
    {
      "name": "SAM3_MAX_UPLOAD_MB",
      "default": "50",
      "required": true
    },
    {
      "name": "SAM3_REAL_INFERENCE",
      "default": "0",
      "required": true
    },
    {
      "name": "SAM3_POLYGON_EPSILON",
      "default": "2.0",
      "required": true
    },
    {
      "name": "SAM3_MAX_POLYGON_POINTS",
      "default": "2000",
      "required": true
    },
    {
      "name": "SAM3_MIN_CONTOUR_AREA",
      "default": "16",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "vram",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18106,
    "local_port_env": "SAM3_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "sam3-main",
    "compose_project": "3waaihub_sam3_main"
  }
}
