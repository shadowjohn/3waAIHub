{
  "schema_version": "0.1",
  "id": "sam3",
  "name": "SAM3 Segmentation Service",
  "version": "0.1.0",
  "category": "vision",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L3-storage-mount",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "sam3",
  "description": "SAM3 segmentation API adapter with storage mount checks and mock segmentation response.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/segment/image",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 50
  },
  "hardware": {
    "gpu_required": true,
    "gpu_supported": true,
    "min_vram_mb": 16000,
    "recommended_vram_mb": 24000,
    "cpu_fallback": false,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "gpu",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "sam3",
        "container_path": "/models/sam3",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "sam3",
        "container_path": "/cache/sam3",
        "read_only": false
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "settings_schema": [
    {
      "key": "SAM3_CHECKPOINT",
      "label": "SAM3 checkpoint",
      "type": "text",
      "default": "",
      "required": false,
      "restart_required": true,
      "model_selector": {
        "type": "file",
        "root_subdir": "sam3",
        "extensions": [".pt", ".pth", ".safetensors", ".ckpt"]
      }
    },
    {
      "key": "SAM3_MODEL_ID",
      "label": "SAM3 model id",
      "type": "text",
      "default": "",
      "required": false,
      "restart_required": true
    },
    {
      "key": "SAM3_DEVICE",
      "label": "Device",
      "type": "select",
      "default": "auto",
      "options": ["auto", "cuda", "cpu"],
      "required": true,
      "restart_required": true
    },
    {
      "key": "SAM3_MAX_UPLOAD_MB",
      "label": "Max upload MB",
      "type": "integer",
      "default": "50",
      "min": 1,
      "max": 1024,
      "required": true,
      "restart_required": false
    },
    {
      "key": "SAM3_REAL_INFERENCE",
      "label": "Enable real SAM3 inference",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "L3 keeps real inference disabled; L4a will add model-present smoke first."
    }
  ],
  "env": [
    {
      "name": "SAM3_CHECKPOINT",
      "default": "",
      "required": false
    },
    {
      "name": "SAM3_MODEL_ID",
      "default": "",
      "required": false
    },
    {
      "name": "SAM3_DEVICE",
      "default": "auto",
      "required": true
    },
    {
      "name": "SAM3_MAX_UPLOAD_MB",
      "default": "50",
      "required": true
    },
    {
      "name": "SAM3_REAL_INFERENCE",
      "default": "0",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "vram",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18106,
    "local_port_env": "SAM3_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "sam3-main",
    "compose_project": "3waaihub_sam3_main"
  }
}
