{
  "schema_version": "0.1",
  "id": "docparser",
  "name": "3waAIHub DocParser",
  "version": "0.1.0",
  "category": "document",
  "type": "orchestrator",
  "execution_type": "async_task",
  "runtime_level": "L5-benchmark-ready",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "docparser",
  "description": "Technical manual PDF complete delivery orchestrator for DocIR, HTML, Markdown, RAG and quality reports.",
  "runtime": {
    "kind": "internal_task",
    "default_internal_port": 0
  },
  "gateway": {
    "health_path": "",
    "invoke_path": "task_submit:docparser_parse",
    "methods": ["POST"],
    "timeout_sec": 1800,
    "max_upload_mb": 500
  },
  "l5_contract": {
    "endpoint": "POST api.php?mode=docparser",
    "method": "POST",
    "content_type": "multipart/form-data",
    "task_type": "docparser_parse",
    "input": {
      "fields": [
        {
          "name": "file",
          "type": "file",
          "required": true,
          "extensions": ["pdf"],
          "max_mb": 500,
          "example": "manual.pdf"
        },
        {
          "name": "target_language",
          "type": "string",
          "required": false,
          "default": "zh-TW"
        },
        {
          "name": "translation_required",
          "type": "boolean",
          "required": false,
          "default": "1"
        },
        {
          "name": "structure_mode",
          "type": "string",
          "required": false,
          "default": "structure"
        },
        {
          "name": "translate_mode",
          "type": "string",
          "required": false,
          "default": "translate"
        }
      ]
    },
    "output": {
      "required_keys": ["ok", "task_id", "status", "status_url", "result_url", "log_url", "artifact_url_template"]
    },
    "task_api": {
      "status": "GET api.php?mode=task_status&task_id={task_id}",
      "result": "GET api.php?mode=task_result&task_id={task_id}",
      "log": "GET api.php?mode=task_log&task_id={task_id}",
      "artifact": "GET api.php?mode=artifact&artifact_id={artifact_id}"
    },
    "task_result": {
      "status": "GET api.php?mode=task_result&task_id={task_id}",
      "queued_status_code": 409,
      "artifact_summary_keys": [
        "reader_html",
        "bilingual_html",
        "markdown",
        "docir",
        "toc",
        "rag_chunks",
        "quality_report",
        "manifest",
        "figure_assets"
      ],
      "figure_item_keys": ["figure_id", "block_id", "page", "bbox", "caption", "asset_path", "artifact_id", "bytes"]
    },
    "errors": ["file_required", "unsupported_file_type", "invalid_pdf_file", "unknown_queue", "missing_token", "token_mode_not_allowed"],
    "benchmark": {
      "supported": true,
      "cases": [
        {
          "id": "docparser_submit_pdf",
          "name": "DocParser single PDF async submit smoke",
          "type": "async_submit",
          "mode": "docparser",
          "method": "POST",
          "fixture": "packs/structure-ppstructurev3/demo/sample.pdf",
          "fixture_field": "file",
          "form": {
            "target_language": "zh-TW",
            "translation_required": "1",
            "structure_mode": "structure",
            "translate_mode": "translate"
          },
          "expected_keys": ["ok", "task_id", "status", "status_url", "result_url", "log_url", "artifact_url_template"]
        },
        {
          "id": "docparser_submit_10page_pdf",
          "name": "DocParser 10 page PDF async submit smoke",
          "type": "async_submit",
          "mode": "docparser",
          "method": "POST",
          "fixture": "packs/structure-ppstructurev3/demo/sample-10-pages.pdf",
          "fixture_field": "file",
          "form": {
            "target_language": "zh-TW",
            "translation_required": "1",
            "structure_mode": "structure",
            "translate_mode": "translate"
          },
          "expected_keys": ["ok", "task_id", "status", "status_url", "result_url", "log_url", "artifact_url_template"]
        }
      ]
    }
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": false,
    "min_vram_mb": 0,
    "cpu_fallback": true,
    "min_compute_capability": "0.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "ocr",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": []
  },
  "settings_schema": [
    {"key": "DOCPARSER_STRUCTURE_MODE", "label": "Structure mode", "type": "text", "default": "structure", "required": true, "restart_required": false},
    {"key": "DOCPARSER_TRANSLATE_MODE", "label": "Translate mode", "type": "text", "default": "translate", "required": false, "restart_required": false},
    {"key": "DOCPARSER_TARGET_LANGUAGE", "label": "Target language", "type": "select", "default": "zh-TW", "options": ["zh-TW", "source"], "required": true, "restart_required": false},
    {"key": "DOCPARSER_TRANSLATION_REQUIRED", "label": "Translation required", "type": "boolean", "default": "1", "required": true, "restart_required": false},
    {"key": "DOCPARSER_PROFILE", "label": "Profile", "type": "select", "default": "technical_manual", "options": ["technical_manual"], "required": true, "restart_required": false}
  ],
  "env": [],
  "preflight": {
    "checks": ["storage"]
  },
  "install": {
    "default_service_key": "docparser-main",
    "compose_project": "3waaihub_docparser_main"
  }
}
