GEMMA4_LOCAL_PORT=18110
VLLM_MODEL=google/gemma-4-12B-it-qat-w4a16-ct
VLLM_SERVED_MODEL_NAME=gemma4-12b
VLLM_BASE_URL=http://vllm:8000
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_MEMORY_UTILIZATION=0.64
VLLM_MAX_NUM_SEQS=1
VLLM_TIMEOUT_SEC=600
MAX_INPUT_CHARS=12000
GEMMA_DEFAULT_THINKING=0
GEMMA4_REAL_INFERENCE=0
GPU_VISIBLE_DEVICES=all
GEMMA4_CACHE_DIR=/cache/gemma4
GEMMA4_SERVICE_DATA_DIR=/data/service
HF_HOME=/root/.cache/huggingface
XDG_CACHE_HOME=/cache/gemma4/xdg
HOME=/cache/gemma4/home
PYTHONUNBUFFERED=1
AIHUB_MODELS_DIR=/DATA/models
AIHUB_CACHE_DIR=/DATA/3waAIHub/data/cache
SERVICE_DATA_DIR=/DATA/3waAIHub/data/services/gemma4-main
