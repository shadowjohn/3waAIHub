{
  "schema_version": "0.1",
  "id": "ocr-ppocrv5",
  "name": "PP-OCRv5 OCR Service",
  "version": "0.1.0",
  "category": "ocr",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L1-gpu-api-mock",
  "runtime_ready": true,
  "default_mode": "ocr",
  "description": "GPU-ready OCR mock service for PP-OCRv5 runtime bring-up.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/ocr/image",
    "methods": ["POST"],
    "timeout_sec": 60,
    "max_upload_mb": 50
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": true,
    "min_vram_mb": 0,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "ocr",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "paddleocr",
        "container_path": "/models/paddleocr",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "paddleocr",
        "container_path": "/cache/paddleocr",
        "read_only": false
      },
      {
        "type": "service",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "env": [
    {
      "name": "OCR_USE_GPU",
      "default": "1",
      "required": true
    },
    {
      "name": "NVIDIA_VISIBLE_DEVICES",
      "default": "all",
      "required": false
    },
    {
      "name": "OCR_MAX_UPLOAD_MB",
      "default": "50",
      "required": true
    },
    {
      "name": "OCR_MOCK_TEXT",
      "default": "3waAIHub OCR mock",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18101,
    "local_port_env": "OCR_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "ocr-main",
    "compose_project": "3waaihub_ocr_main"
  }
}
