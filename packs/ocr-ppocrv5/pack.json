{
  "schema_version": "0.1",
  "id": "ocr-ppocrv5",
  "name": "PP-OCRv5 OCR Service",
  "version": "0.1.0",
  "category": "ocr",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L5-benchmark-ready",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "ocr",
  "description": "GPU-ready OCR service with PaddleOCR real image inference and mock fallback.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/ocr/image",
    "methods": ["POST"],
    "timeout_sec": 60,
    "max_upload_mb": 50
  },
  "l5_contract": {
    "endpoint": "/ocr/image",
    "method": "POST",
    "content_type": "multipart/form-data",
    "input": {
      "fields": [
        {
          "name": "image",
          "type": "file",
          "required": true,
          "max_mb": 50
        },
        {
          "name": "real_inference",
          "type": "boolean",
          "required": false,
          "default": "0",
          "description": "Set to 1 to run PaddleOCR real image inference for this request."
        }
      ]
    },
    "output": {
      "required_keys": ["ok", "text", "blocks"],
      "block_keys": ["text", "bbox", "confidence"]
    },
    "errors": [
      "bad_request",
      "file_too_large",
      "runtime_not_ready",
      "inference_failed",
      "gateway_timeout"
    ],
    "limits": {
      "timeout_sec": 60,
      "max_upload_mb": 50,
      "max_concurrency": 1
    },
    "benchmark": {
      "supported": true,
      "cases": [
        {
          "id": "ocr_mock_image",
          "name": "OCR mock image smoke",
          "type": "api",
          "mode": "ocr",
          "method": "POST",
          "fixture": "packs/ocr-ppocrv5/demo/sample.png",
          "expected_keys": ["ok", "text", "blocks"]
        },
        {
          "id": "ocr_real_image",
          "name": "OCR real image inference smoke",
          "type": "api",
          "mode": "ocr",
          "method": "POST",
          "fixture": "packs/ocr-ppocrv5/demo/real_sample.png",
          "expected_keys": ["ok", "text", "blocks"],
          "expected_min_blocks": 1,
          "real_inference": true
        }
      ]
    }
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": true,
    "min_vram_mb": 0,
    "min_compute_capability": "8.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "ocr",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "paddleocr",
        "container_path": "/models/paddleocr",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "paddleocr",
        "container_path": "/cache/paddleocr",
        "read_only": false
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "settings_schema": [
    {
      "key": "OCR_MAX_UPLOAD_MB",
      "label": "Max upload MB",
      "type": "integer",
      "default": "50",
      "min": 1,
      "max": 1024,
      "required": true,
      "restart_required": false
    },
    {
      "key": "OCR_MOCK_TEXT",
      "label": "Mock OCR text",
      "type": "text",
      "default": "3waAIHub OCR mock",
      "required": true,
      "restart_required": true
    },
    {
      "key": "OCR_REAL_INFERENCE",
      "label": "Enable real OCR inference",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "Default to mock mode unless this is enabled or a benchmark explicitly requests real inference."
    },
    {
      "key": "OCR_USE_GPU",
      "label": "Use GPU",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true
    },
    {
      "key": "OCR_LANG",
      "label": "OCR language",
      "type": "select",
      "default": "ch",
      "options": ["ch", "en", "japan", "korean", "auto"],
      "required": true,
      "restart_required": true
    },
    {
      "key": "KEEP_WARM",
      "label": "Keep model warm",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "Preload model at service startup when supported."
    }
  ],
  "env": [
    {
      "name": "OCR_USE_GPU",
      "default": "1",
      "required": true
    },
    {
      "name": "NVIDIA_VISIBLE_DEVICES",
      "default": "all",
      "required": false
    },
    {
      "name": "OCR_MAX_UPLOAD_MB",
      "default": "50",
      "required": true
    },
    {
      "name": "OCR_MOCK_TEXT",
      "default": "3waAIHub OCR mock",
      "required": true
    },
    {
      "name": "OCR_REAL_INFERENCE",
      "default": "0",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "nvidia_smi",
      "docker_gpus",
      "compute_capability",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18101,
    "local_port_env": "OCR_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "ocr-main",
    "compose_project": "3waaihub_ocr_main"
  }
}
