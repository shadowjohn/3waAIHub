{
  "schema_version": "0.1",
  "id": "ocr-ppocrv5",
  "name": "PP-OCRv5 OCR Service",
  "version": "0.1.0",
  "category": "ocr",
  "type": "api_service",
  "execution_type": "sync_api",
  "default_mode": "ocr",
  "description": "OCR service powered by PP-OCRv5.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/ocr/image",
    "methods": ["POST"],
    "timeout_sec": 60,
    "max_upload_mb": 50
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": true,
    "min_vram_mb": 0
  },
  "queue": {
    "supported": true,
    "default_queue": "ocr",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "paddleocr",
        "container_path": "/models/paddleocr",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "paddleocr",
        "container_path": "/cache/paddleocr",
        "read_only": false
      }
    ]
  },
  "env": [
    {
      "name": "OCR_LANG",
      "default": "ch",
      "required": true
    }
  ],
  "service": {
    "default_local_port": 18101,
    "local_port_env": "OCR_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "ocr-main",
    "compose_project": "3waaihub_ocr_main"
  }
}
