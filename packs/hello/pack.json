{
  "schema_version": "0.1",
  "id": "hello",
  "name": "hello-service",
  "version": "0.1.0",
  "category": "demo",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L1-api-mock",
  "runtime_ready": true,
  "default_mode": "hello",
  "description": "Minimal hello service for 3waAIHub smoke tests.",
  "gpu_required": false,
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/",
    "methods": ["GET"],
    "timeout_sec": 10,
    "max_upload_mb": 1
  },
  "hardware": {
    "gpu_required": false,
    "gpu_supported": false,
    "min_vram_mb": 0
  },
  "queue": {
    "supported": false,
    "default_queue": "default",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": []
  },
  "env": [],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose"
    ]
  },
  "service": {
    "internal_port": 8000,
    "health_path": "/health",
    "default_local_port": 18100,
    "local_port_env": "HELLO_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "hello-main",
    "compose_project": "3waaihub_hello"
  },
  "capabilities": {
    "benchmark_supported": false,
    "supports_hot_reload": false
  }
}
