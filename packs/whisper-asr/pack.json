{
  "schema_version": "0.1",
  "id": "whisper-asr",
  "name": "Whisper ASR Service",
  "version": "0.1.0",
  "category": "asr",
  "type": "api_service",
  "execution_type": "sync_api",
  "runtime_level": "L3-storage-mount",
  "target_level": "L5-benchmark-ready",
  "runtime_ready": true,
  "default_mode": "asr",
  "description": "Whisper-compatible audio transcription API adapter with dependency import smoke and storage mount checks.",
  "runtime": {
    "kind": "docker",
    "compose_file": "docker-compose.yml",
    "default_internal_port": 8000
  },
  "gateway": {
    "health_path": "/health",
    "invoke_path": "/asr/audio",
    "methods": ["POST"],
    "timeout_sec": 180,
    "max_upload_mb": 100
  },
  "async_jobs": [
    {
      "job": "transcribe",
      "input": {
        "fields": [],
        "source_artifact_types": ["audio"]
      },
      "output": {
        "artifacts": [
          {
            "type": "transcript_json",
            "path": "transcript.json",
            "mime_types": ["application/json"],
            "max_bytes": 2097152,
            "json": {
              "required_keys": ["text"]
            }
          }
        ]
      }
    }
  ],
  "hardware": {
    "gpu_required": false,
    "gpu_supported": true,
    "min_vram_mb": 0,
    "cpu_fallback": true,
    "min_compute_capability": "0.0"
  },
  "queue": {
    "supported": true,
    "default_queue": "default",
    "max_concurrency": 1
  },
  "storage": {
    "mounts": [
      {
        "type": "models",
        "host_subdir": "whisper",
        "container_path": "/models/whisper",
        "read_only": false
      },
      {
        "type": "cache",
        "host_subdir": "whisper",
        "container_path": "/cache/whisper",
        "read_only": false
      },
      {
        "type": "service_data",
        "host_subdir": "",
        "container_path": "/data/service",
        "read_only": false
      }
    ]
  },
  "settings_schema": [
    {
      "key": "WHISPER_MODEL",
      "label": "Whisper model",
      "type": "text",
      "default": "small",
      "required": true,
      "restart_required": true
    },
    {
      "key": "WHISPER_DEVICE",
      "label": "Device",
      "type": "select",
      "default": "auto",
      "options": ["auto", "cpu", "cuda"],
      "required": true,
      "restart_required": true
    },
    {
      "key": "WHISPER_COMPUTE_TYPE",
      "label": "Compute type",
      "type": "select",
      "default": "int8",
      "options": ["int8", "float16", "float32"],
      "required": true,
      "restart_required": true
    },
    {
      "key": "WHISPER_REAL_INFERENCE",
      "label": "Enable real ASR inference",
      "type": "boolean",
      "default": "0",
      "required": true,
      "restart_required": true,
      "help": "L3 keeps real transcription disabled."
    },
    {
      "key": "WHISPER_MAX_UPLOAD_MB",
      "label": "Max upload MB",
      "type": "integer",
      "default": "100",
      "min": 1,
      "max": 1024,
      "required": true,
      "restart_required": false
    }
  ],
  "env": [
    {
      "name": "WHISPER_MODEL",
      "default": "small",
      "required": true
    },
    {
      "name": "WHISPER_DEVICE",
      "default": "auto",
      "required": true
    },
    {
      "name": "WHISPER_COMPUTE_TYPE",
      "default": "int8",
      "required": true
    },
    {
      "name": "WHISPER_REAL_INFERENCE",
      "default": "0",
      "required": true
    },
    {
      "name": "WHISPER_MAX_UPLOAD_MB",
      "default": "100",
      "required": true
    }
  ],
  "preflight": {
    "checks": [
      "docker",
      "docker_compose",
      "storage"
    ]
  },
  "service": {
    "default_local_port": 18107,
    "local_port_env": "ASR_LOCAL_PORT"
  },
  "install": {
    "default_service_key": "asr-main",
    "compose_project": "3waaihub_asr_main"
  }
}
